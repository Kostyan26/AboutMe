<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Konstantin — Software Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #111118;
      --border: #1e1e2e;
      --accent: #5cffb1;
      --accent2: #4fc3f7;
      --accent3: #f472b6;
      --text: #e8e8f0;
      --muted: #6b6b80;
      --card: #13131d;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── GRID NOISE BACKGROUND ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(92,255,177,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(92,255,177,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── GLOW ORBS ── */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
    }
    .orb-1 { width: 500px; height: 500px; background: var(--accent); top: -150px; right: -100px; animation: drift1 18s ease-in-out infinite; }
    .orb-2 { width: 400px; height: 400px; background: var(--accent2); bottom: 100px; left: -150px; animation: drift2 22s ease-in-out infinite; }
    .orb-3 { width: 300px; height: 300px; background: var(--accent3); top: 50%; left: 50%; animation: drift3 15s ease-in-out infinite; }

    @keyframes drift1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-40px,60px)} }
    @keyframes drift2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(60px,-40px)} }
    @keyframes drift3 { 0%,100%{transform:translate(-50%,-50%)} 50%{transform:translate(-55%,-45%)} }

    /* ── WRAPPER ── */
    .wrap {
      position: relative;
      z-index: 1;
      max-width: 860px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── NAV ── */
    nav {
      position: relative;
      z-index: 10;
      padding: 28px 0 0;
    }
    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .nav-tag {
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    /* ── HERO ── */
    .hero {
      padding: 90px 0 70px;
      animation: fadeUp 0.9s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid rgba(92,255,177,0.25);
      padding: 6px 14px;
      border-radius: 2px;
      margin-bottom: 36px;
    }
    .hero-label::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse 2s ease infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }

    .hero-name {
      font-family: 'Syne', sans-serif;
      font-size: clamp(3rem, 9vw, 5.5rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 16px;
    }
    .hero-name span {
      color: var(--accent);
      display: block;
    }

    .hero-role {
      font-size: 0.85rem;
      color: var(--muted);
      letter-spacing: 0.06em;
      margin-bottom: 32px;
    }

    .hero-desc {
      font-size: 0.95rem;
      line-height: 1.8;
      color: #a0a0b8;
      max-width: 580px;
      margin-bottom: 48px;
    }

    /* ── DIVIDER ── */
    .line {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, var(--accent), transparent);
      opacity: 0.2;
      margin: 56px 0;
    }

    /* ── SERVICES ── */
    .section-label {
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 28px;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      animation: fadeUp 1s 0.2s ease both;
    }

    .service-card {
      background: var(--card);
      padding: 32px 28px;
      position: relative;
      overflow: hidden;
      transition: background 0.3s;
    }
    .service-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 2px;
      background: var(--accent);
      transition: width 0.4s ease;
    }
    .service-card:hover { background: #161621; }
    .service-card:hover::after { width: 100%; }

    .service-icon {
      font-size: 1.5rem;
      margin-bottom: 16px;
      display: block;
    }
    .service-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 10px;
    }
    .service-desc {
      font-size: 0.78rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* ── STACK ── */
    .stack-section { animation: fadeUp 1s 0.35s ease both; }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .tag {
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 6px 14px;
      border: 1px solid var(--border);
      color: var(--muted);
      background: var(--card);
      transition: all 0.25s;
      cursor: default;
    }
    .tag:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* ── CONTACT ── */
    .contact-section { animation: fadeUp 1s 0.5s ease both; }

    .contact-block {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .contact-row {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 0.82rem;
    }
    .contact-key {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      min-width: 100px;
    }
    .contact-val {
      color: var(--text);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.25s, color 0.25s;
    }
    .contact-val:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    /* ── FOOTER ── */
    footer {
      padding: 52px 0 36px;
      text-align: center;
    }
    .footer-inner {
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.08em;
    }
    .footer-copy {
      color: rgba(92,255,177,0.5);
    }

    /* ── CORNER DECORATION ── */
    .corner {
      position: fixed;
      bottom: 32px; right: 32px;
      width: 60px; height: 60px;
      border-right: 2px solid rgba(92,255,177,0.2);
      border-bottom: 2px solid rgba(92,255,177,0.2);
      pointer-events: none;
      z-index: 0;
    }

    @media (max-width: 600px) {
      .hero { padding: 60px 0 50px; }
      .services-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

